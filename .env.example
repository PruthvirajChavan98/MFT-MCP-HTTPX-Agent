# ============================================================
# ROOT .env — Single source of truth for all environments
# Used for:
#   1. Docker Compose ${VAR} interpolation in compose YAMLs
#   2. env_file: mount into containers (mcp, agent, cloudflared, etc.)
#   3. Bare-metal local dev defaults (overridden by compose environment: blocks)
# ============================================================

# ── Database Credentials ─────────────────────────────────────
POSTGRES_DB=mft_security
POSTGRES_USER=mft
POSTGRES_PASSWORD=changeme

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=changeme

# ── Cloudflare Tunnel ─────────────────────────────────────────
TUNNEL_TOKEN=your-token-here

# ── GeoIP (optional — free mode works without these) ──────────
MAXMIND_ACCOUNT_ID=
MAXMIND_LICENSE_KEY=
IP2PROXY_LITE_URL=

# ── OpenRouter (passed through to agent container) ────────────
OPENROUTER_SITE_URL=https://frontend.pruthvirajchavan.codes
OPENROUTER_APP_TITLE=MFT Agent Console

# ── Port Overrides (local compose only — defaults shown) ──────
LOCAL_REDIS_PORT=16379
LOCAL_POSTGRES_PORT=15432
LOCAL_MCP_PORT=18050
LOCAL_AGENT_PORT=18000
LOCAL_PROMETHEUS_PORT=19090
LOCAL_ALERTMANAGER_PORT=19093
LOCAL_GRAFANA_PORT=13000

# ── CRM Integration ───────────────────────────────────────────
CRM_BASE_URL=https://test-mock-crm.pruthvirajchavan.codes
BASIC_AUTH_USERNAME=your-username-here
BASIC_AUTH_PASSWORD=changeme

# ── LLM Provider Keys ─────────────────────────────────────────
# Groq (pool of round-robin keys)
BASE_URL=https://api.groq.com
GROQ_API_KEYS=your-key-here

# BYOK — leave empty for pure bring-your-own-key mode
OPENROUTER_API_KEY=your-key-here
GROQ_API_KEY=
NVIDIA_API_KEY=your-key-here

# ── Bare-metal Dev Defaults (overridden by compose environment: blocks) ──
REDIS_URL=redis://localhost:6379/0
MILVUS_URI=http://localhost:19530

# ── FAQ Classifier ────────────────────────────────────────────
FAQ_CLASSIFIER_MODEL=openai/gpt-oss-120b
FAQ_CLASSIFIER_BATCH_SIZE=30

# ── Eval & Judging ────────────────────────────────────────────
EVAL_INGEST_KEY=changeme
ENABLE_LLM_JUDGE=1
JUDGE_MODEL_NAME=gpt-oss-120b
SHADOW_JUDGE_MODEL=openai/gpt-oss-120b

# Shadow eval
SHADOW_EVAL_ENABLED=1
SHADOW_EVAL_SAMPLE_RATE=0.1
SHADOW_EVAL_CAPTURE=full
SHADOW_EVAL_MAX_PER_MIN=20

# ── Compose Interpolation (compose.yaml) ──────────────────────
# Defaults = local dev. Overridden by .env.local / .env.uat / .env.prod
MFT_NETWORK_NAME=mft_local
REDIS_PORT=16379
POSTGRES_PORT=15432
MCP_PORT=18050
AGENT_PORT=8005
PROMETHEUS_PORT=19090
ALERTMANAGER_PORT=19093
GRAFANA_PORT=13000
PROD_FRONTEND_PORT=5173
AGENT_GUNICORN_TIMEOUT=0
DOWNLOAD_PROXY_BASE_URL=https://mft-agent.pruthvirajchavan.codes

# ── CORS Configuration ───────────────────────────────────────
# Comma-separated list of allowed origins. Defaults to localhost dev origins.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173

# ── Admin Authentication (JWT + TOTP — plan 2026-04-10) ──────
# Runtime kill switch — flipping to false reverts to legacy X-Admin-Key path
# until Phase 6h deletes the legacy code. See tasks/todo.md §6a-additive.
#
# To enroll the super-admin and generate all required values below, run:
#   cd backend && uv run python scripts/enroll_super_admin.py
# then paste the emitted env block over the placeholders below.
ADMIN_AUTH_ENABLED=false

# JWT signing secret — MUST be >=32 bytes when ADMIN_AUTH_ENABLED=true.
# Enrollment script generates this automatically. Manual alternative:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=

# Fernet master key for TOTP secret at-rest encryption.
# Enrollment script generates this automatically. Manual alternative:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_MASTER_KEY=

# Single super-admin identity — populate via the enrollment script above.
# SUPER_ADMIN_PASSWORD_HASH is argon2id; SUPER_ADMIN_TOTP_SECRET_ENC is the
# Fernet-encrypted base32 TOTP secret (decrypts with FERNET_MASTER_KEY).
SUPER_ADMIN_EMAIL=
SUPER_ADMIN_PASSWORD_HASH=
SUPER_ADMIN_TOTP_SECRET_ENC=

# Optional overrides (defaults shown in backend/src/agent_service/core/config.py):
# JWT_ALGORITHM=HS256
# JWT_ISSUER=mft-agent-service
# JWT_AUDIENCE=mft-admin-console
# JWT_ACCESS_TTL_SECONDS=900
# JWT_REFRESH_TTL_SECONDS=28800
# JWT_MFA_FRESHNESS_SECONDS=300
# ADMIN_AUTH_COOKIE_SECURE=true    # set false only for local HTTP dev
# ADMIN_AUTH_COOKIE_NAME_ACCESS=mft_admin_at
# ADMIN_AUTH_COOKIE_NAME_REFRESH=mft_admin_rt
