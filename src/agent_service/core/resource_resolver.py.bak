"""
Agent Resource Resolution
Handles model, tool, and configuration resolution for agent requests.
"""
import logging
from typing import Optional, List, Any
from dataclasses import dataclass

from src.agent_service.core.config import MODEL_NAME, SYSTEM_PROMPT
from src.agent_service.core.schemas import AgentRequest
from src.agent_service.data.config_manager import config_manager
from src.agent_service.llm.client import get_llm
from src.agent_service.tools.mcp_manager import mcp_manager

log = logging.getLogger(__name__)


@dataclass
class ResolvedResources:
    """
    Container for resolved agent resources.
    Immutable dataclass for type safety and clarity.
    """
    model: Any
    tools: List[Any]
    system_prompt: str
    api_key: Optional[str]
    model_name: str
    provider: str
    reasoning_effort: Optional[str] = None


class ResourceResolver:
    """
    Resolves models, tools, and configurations for agent execution.
    
    Priority hierarchy:
    1. Request parameters (highest priority)
    2. Saved session configuration
    3. Global defaults (lowest priority)
    """
    
    @staticmethod
    def infer_provider_from_model_name(model_name: Optional[str]) -> str:
        """
        Infer provider from model name prefix.
        
        Args:
            model_name: Model identifier (e.g., "nvidia/llama-3.1-nemotron-70b")
            
        Returns:
            Provider name: "nvidia", "groq", "openrouter", or default "groq"
            
        Examples:
            >>> ResourceResolver.infer_provider_from_model_name("nvidia/llama-3.1")
            'nvidia'
            >>> ResourceResolver.infer_provider_from_model_name("anthropic/claude-3")
            'openrouter'
            >>> ResourceResolver.infer_provider_from_model_name("llama-70b")
            'groq'
        """
        if not model_name:
            return "groq"
        
        mn = model_name.strip().lower()
        
        if mn.startswith("nvidia/"):
            return "nvidia"
        if mn.startswith("groq/"):
            return "groq"
        if "/" in mn:  # Assumes OpenRouter format
            return "openrouter"
        
        return "groq"  # Default fallback
    
    @staticmethod
    async def resolve_agent_resources(
        session_id: str, 
        request: AgentRequest
    ) -> ResolvedResources:
        """
        Resolve all resources needed for agent execution.
        
        Args:
            session_id: Validated session identifier
            request: Incoming agent request with optional overrides
            
        Returns:
            ResolvedResources containing model, tools, prompts, and metadata
            
        Raises:
            ValueError: If resource resolution fails
            
        Example:
            resources = await resource_resolver.resolve_agent_resources(
                "session_123",
                AgentRequest(question="What is AI?", model_name="gpt-4")
            )
            agent = create_agent(resources.model, resources.tools)
        """
        try:
            # Fetch saved configuration
            saved_config = await config_manager.get_config(session_id)
            
            # Model name resolution (priority: request > saved > default)
            model_name = (
                request.model_name 
                or saved_config.get("model_name") 
                or MODEL_NAME
            )
            
            # System prompt resolution
            system_prompt = (
                request.system_prompt 
                or saved_config.get("system_prompt") 
                or SYSTEM_PROMPT.strip()
            )
            
            # Reasoning effort resolution (o1/o3 models)
            reasoning_effort = (
                request.reasoning_effort 
                or saved_config.get("reasoning_effort")
            )
            
            # Provider resolution
            provider = (
                request.provider 
                or saved_config.get("provider") 
                or ResourceResolver.infer_provider_from_model_name(model_name)
            )
            
            # API key resolution (priority: request > saved config > None)
            openrouter_key = (
                request.openrouter_api_key 
                or saved_config.get("openrouter_api_key")
            )
            nvidia_key = (
                request.nvidia_api_key 
                or saved_config.get("nvidia_api_key")
            )
            groq_key = (
                request.groq_api_key 
                or saved_config.get("groq_api_key")
            )
            
            # Unified LLM factory initialization
            model = get_llm(
                model_name=model_name,
                provider=provider,
                openrouter_api_key=openrouter_key,
                nvidia_api_key=nvidia_key,
                groq_api_key=groq_key,
                reasoning_effort=reasoning_effort
            )
            
            # Rebuild tools for user context
            tools = mcp_manager.rebuild_tools_for_user(
                session_id, 
                openrouter_api_key=openrouter_key
            )
            
            log.info(
                f"Resolved resources for {session_id}: "
                f"model={model_name}, provider={provider}, tools={len(tools)}"
            )
            
            # Return unified resource container
            return ResolvedResources(
                model=model,
                tools=tools,
                system_prompt=system_prompt,
                api_key=openrouter_key,  # Primary API key
                model_name=model_name,
                provider=provider,
                reasoning_effort=reasoning_effort
            )
            
        except Exception as e:
            log.error(f"Resource resolution failed for session {session_id}: {e}")
            raise ValueError(f"Failed to resolve agent resources: {e}") from e


# Singleton instance
resource_resolver = ResourceResolver()
