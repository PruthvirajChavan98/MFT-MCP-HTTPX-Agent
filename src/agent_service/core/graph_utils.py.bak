"""
LangGraph-specific Utilities
Handles state management, message history, and graph reducers.
"""
import logging
from typing import Dict, Any, List
from langchain_core.messages import RemoveMessage, BaseMessage

from src.agent_service.core.config import KEEP_LAST

log = logging.getLogger(__name__)


class GraphUtils:
    """Utilities for LangGraph state management and message handling."""
    
    @staticmethod
    def keep_only_last_n_messages(
        state: Dict[str, Any], 
        config: Dict[str, Any],
        n: int = KEEP_LAST
    ) -> Dict[str, Any]:
        """
        LangGraph reducer to keep message history short.
        
        Prevents context window overflow by removing older messages
        while preserving recent conversation history.
        
        Args:
            state: Current graph state with 'messages' key
            config: Graph configuration (unused, required by LangGraph)
            n: Number of messages to keep (default from KEEP_LAST config)
            
        Returns:
            Update dict with RemoveMessage commands for old messages,
            empty dict if no messages to remove
            
        Example:
            # In LangGraph graph definition:
            from langgraph.graph import StateGraph
            from src.agent_service.core.graph_utils import graph_utils
            
            graph = StateGraph(AgentState)
            graph.add_node("trim", graph_utils.keep_only_last_n_messages)
        """
        msgs: List[BaseMessage] = list(state.get("messages", []))
        
        if len(msgs) <= n:
            return {}
        
        # Remove oldest messages beyond the keep limit
        messages_to_remove = [
            RemoveMessage(id=msgs[i].id) 
            for i in range(len(msgs) - n)
            if msgs[i].id is not None
        ]
        
        log.debug(f"Trimming {len(messages_to_remove)} messages (keeping last {n})")
        return {"messages": messages_to_remove}
    
    @staticmethod
    def get_last_n_messages(
        state: Dict[str, Any], 
        n: int = KEEP_LAST
    ) -> List[BaseMessage]:
        """
        Extract last N messages from graph state.
        
        Args:
            state: Graph state with 'messages' key
            n: Number of messages to retrieve
            
        Returns:
            List of last N messages
        """
        msgs: List[BaseMessage] = list(state.get("messages", []))
        return msgs[-n:] if len(msgs) > n else msgs
    
    @staticmethod
    def count_messages(state: Dict[str, Any]) -> int:
        """
        Count total messages in graph state.
        
        Args:
            state: Graph state with 'messages' key
            
        Returns:
            Total message count
        """
        return len(state.get("messages", []))
    
    @staticmethod
    def filter_messages_by_type(
        state: Dict[str, Any], 
        message_type: str
    ) -> List[BaseMessage]:
        """
        Filter messages by type (HumanMessage, AIMessage, etc.).
        
        Args:
            state: Graph state with 'messages' key
            message_type: Message class name to filter by
            
        Returns:
            List of messages matching the type
        """
        msgs: List[BaseMessage] = list(state.get("messages", []))
        return [m for m in msgs if m.__class__.__name__ == message_type]


# Singleton instance
graph_utils = GraphUtils()


# Backward compatibility function
def keep_only_last_n_messages(state: dict, config: dict) -> Dict[str, Any]:
    """
    DEPRECATED: Use graph_utils.keep_only_last_n_messages() instead.
    Kept for backward compatibility with existing LangGraph definitions.
    """
    return graph_utils.keep_only_last_n_messages(state, config)
