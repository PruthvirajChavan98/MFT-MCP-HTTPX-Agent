"""
Session Management & Authentication Utilities
Handles session validation, Redis operations, and authentication checks.
"""
import json
import logging
from typing import Optional, Dict, Any
from redis import Redis
from redis.asyncio import Redis as AsyncRedis

from src.agent_service.core.config import REDIS_URL

log = logging.getLogger(__name__)


class SessionUtils:
    """
    Centralized session management and authentication utilities.
    Thread-safe Redis operations for session validation and auth checks.
    """
    
    @staticmethod
    def validate_session_id(session_id: object) -> str:
        """
        Ensures session_id is a valid non-empty string.
        
        Args:
            session_id: Raw session ID from request (any type)
            
        Returns:
            Validated session ID string
            
        Raises:
            ValueError: If session_id is invalid or empty
            
        Examples:
            >>> SessionUtils.validate_session_id("abc123")
            'abc123'
            >>> SessionUtils.validate_session_id(None)
            ValueError: Invalid session_id: None
            >>> SessionUtils.validate_session_id("  null  ")
            ValueError: Invalid session_id: '  null  '
        """
        sid = str(session_id).strip() if session_id is not None else ""
        if not sid or sid.lower() in {"null", "none"}:
            raise ValueError(f"Invalid session_id: {session_id!r}")
        return sid
    
    @staticmethod
    def is_user_authenticated(session_id: str) -> bool:
        """
        Check if user has an active access_token in Redis.
        Prevents exposing sensitive tool definitions to unauthenticated users.
        
        Args:
            session_id: Validated session identifier
            
        Returns:
            True if user has valid access_token, False otherwise
            
        Note:
            Uses synchronous Redis client for thread-safe operation.
            MCP Session Store saves data directly against session_id key.
        """
        try:
            # Thread-safe synchronous Redis client
            client = Redis.from_url(REDIS_URL, decode_responses=True)
            data_str = client.get(session_id)
            
            if not data_str:
                return False
            
            data = json.loads(str(data_str))
            # Check for access_token set by auth_api.py
            return bool(data.get("access_token"))
            
        except Exception as e:
            log.warning(f"Auth check failed for session {session_id}: {e}")
            return False
    
    @staticmethod
    async def get_app_id_for_session(session_id: str) -> Optional[str]:
        """
        Retrieve app_id associated with a session from Redis (async).
        
        Args:
            session_id: Session identifier
            
        Returns:
            app_id if found, None otherwise
        """
        try:
            client = AsyncRedis.from_url(REDIS_URL, decode_responses=True)
            data_str = await client.get(session_id)
            await client.close()
            
            if data_str:
                data = json.loads(str(data_str))
                return data.get("app_id")
        except Exception as e:
            log.warning(f"Failed to retrieve app_id for session {session_id}: {e}")
        
        return None
    
    @staticmethod
    async def get_session_metadata(session_id: str) -> Dict[str, Any]:
        """
        Retrieve full session metadata from Redis (async).
        
        Args:
            session_id: Session identifier
            
        Returns:
            Dictionary containing session metadata, empty dict if not found
        """
        try:
            client = AsyncRedis.from_url(REDIS_URL, decode_responses=True)
            data_str = await client.get(session_id)
            await client.close()
            
            if data_str:
                return json.loads(str(data_str))
        except Exception as e:
            log.error(f"Failed to retrieve metadata for session {session_id}: {e}")
        
        return {}
    
    @staticmethod
    async def set_session_metadata(
        session_id: str, 
        metadata: Dict[str, Any],
        ttl: Optional[int] = None
    ) -> bool:
        """
        Store session metadata in Redis (async).
        
        Args:
            session_id: Session identifier
            metadata: Metadata dictionary to store
            ttl: Optional TTL in seconds (None = no expiration)
            
        Returns:
            True if successful, False otherwise
        """
        try:
            client = AsyncRedis.from_url(REDIS_URL, decode_responses=True)
            serialized = json.dumps(metadata)
            
            if ttl:
                await client.setex(session_id, ttl, serialized)
            else:
                await client.set(session_id, serialized)
            
            await client.close()
            return True
        except Exception as e:
            log.error(f"Failed to set metadata for session {session_id}: {e}")
            return False
    
    @staticmethod
    def get_session_data_sync(session_id: str) -> Dict[str, Any]:
        """
        Retrieve session data synchronously (for non-async contexts).
        
        Args:
            session_id: Session identifier
            
        Returns:
            Session data dictionary, empty if not found
        """
        try:
            client = Redis.from_url(REDIS_URL, decode_responses=True)
            data_str = client.get(session_id)
            
            if data_str:
                return json.loads(str(data_str))
        except Exception as e:
            log.error(f"Sync fetch failed for session {session_id}: {e}")
        
        return {}


# Singleton instance for convenience
session_utils = SessionUtils()


# Backward compatibility aliases
def valid_session_id(session_id: object) -> str:
    """DEPRECATED: Use session_utils.validate_session_id() instead."""
    return session_utils.validate_session_id(session_id)


def is_user_authenticated(session_id: str) -> bool:
    """DEPRECATED: Use session_utils.is_user_authenticated() instead."""
    return session_utils.is_user_authenticated(session_id)
